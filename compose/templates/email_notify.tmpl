<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration Confirmation</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: #18181b;
            color: #fafafa;
            padding: 32px 16px;
            -webkit-font-smoothing: antialiased;
        }

        .wrapper {
            max-width: 560px;
            margin: 0 auto;
        }

        /* App name / logo bar */
        .brand {
            text-align: center;
            padding-bottom: 24px;
        }

        .brand-name {
            font-size: 20px;
            font-weight: 700;
            color: #fafafa;
            letter-spacing: -0.3px;
        }

        /* Main card */
        .card {
            background-color: #27272a;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.10);
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
        }

        /* Accent banner at the top of the card */
        .card-accent {
            height: 4px;
            background: rgba(255, 255, 255, 0.12);
        }

        .card-body {
            padding: 40px 40px 32px;
        }

        .card-title {
            font-size: 22px;
            font-weight: 700;
            color: #fafafa;
            margin-bottom: 8px;
            letter-spacing: -0.3px;
        }

        .card-subtitle {
            font-size: 14px;
            color: rgba(250, 250, 250, 0.5);
            margin-bottom: 24px;
        }

        .divider {
            height: 1px;
            background: rgba(255, 255, 255, 0.07);
            margin: 24px 0;
        }

        .message {
            font-size: 15px;
            line-height: 1.65;
            color: rgba(250, 250, 250, 0.72);
            margin-bottom: 28px;
        }

        /* CTA button */
        .btn-wrap {
            text-align: center;
            margin-bottom: 28px;
        }

        .button {
            display: inline-block;
            padding: 13px 32px;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            font-size: 15px;
            font-weight: 600;
            color: #18181b !important;
            background: #fafafa;
            text-decoration: none;
            border-radius: 10px;
            letter-spacing: 0.1px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
        }

        .note {
            font-size: 13px;
            color: rgba(250, 250, 250, 0.4);
            line-height: 1.6;
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 24px 16px 8px;
        }

        .footer p {
            font-size: 12px;
            color: rgba(250, 250, 250, 0.28);
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="brand">
            <span class="brand-name">{{.AppName}}</span>
        </div>

        <div class="card">
            <div class="card-accent"></div>
            <div class="card-body">
                <h1 class="card-title">Confirm your email</h1>
                <p class="card-subtitle">Welcome to {{.AppName}} — one step away!</p>

                <div class="divider"></div>

                <p class="message">
                    Hey there! Thanks for signing up. To activate your account and start chatting,
                    please verify your email address by clicking the button below.
                </p>

                <div class="btn-wrap">
                    <a href="{{.BaseURL}}/confirm/{{.UserId}}/{{.Token}}" class="button">Confirm Email Address</a>
                </div>

                <p class="note">
                    This link is unique to your account. If you didn't create an account with
                    {{.AppName}}, you can safely ignore this email.
                </p>
            </div>
        </div>

        <div class="footer">
            <p>&copy; {{.Year}} {{.AppName}}. All rights reserved.</p>
        </div>
    </div>
</body>
</html>
