<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Password Reset</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: #18181b;
            color: #fafafa;
            padding: 32px 16px;
            -webkit-font-smoothing: antialiased;
        }

        .wrapper {
            max-width: 560px;
            margin: 0 auto;
        }

        /* App name / logo bar */
        .brand {
            text-align: center;
            padding-bottom: 24px;
        }

        .brand-name {
            font-size: 20px;
            font-weight: 700;
            color: #fafafa;
            letter-spacing: -0.3px;
        }

        /* Main card */
        .card {
            background-color: #27272a;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.10);
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
        }

        /* Accent banner — destructive red for security context */
        .card-accent {
            height: 4px;
            background: #ef4444;
        }

        .card-body {
            padding: 40px 40px 32px;
        }

        .card-title {
            font-size: 22px;
            font-weight: 700;
            color: #fafafa;
            margin-bottom: 8px;
            letter-spacing: -0.3px;
        }

        .card-subtitle {
            font-size: 14px;
            color: rgba(250, 250, 250, 0.5);
            margin-bottom: 24px;
        }

        .divider {
            height: 1px;
            background: rgba(255, 255, 255, 0.07);
            margin: 24px 0;
        }

        .message {
            font-size: 15px;
            line-height: 1.65;
            color: rgba(250, 250, 250, 0.72);
            margin-bottom: 28px;
        }

        /* CTA button */
        .btn-wrap {
            text-align: center;
            margin-bottom: 28px;
        }

        .button {
            display: inline-block;
            padding: 13px 32px;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            font-size: 15px;
            font-weight: 600;
            color: #fafafa !important;
            background: #ef4444;
            text-decoration: none;
            border-radius: 10px;
            letter-spacing: 0.1px;
            box-shadow: 0 4px 16px rgba(239, 68, 68, 0.3);
        }

        /* Expiry notice box */
        .notice {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 12px 16px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .notice svg {
            width: 16px;
            height: 16px;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .notice-text {
            font-size: 13px;
            color: rgba(250, 250, 250, 0.5);
            line-height: 1.55;
        }

        .note {
            font-size: 13px;
            color: rgba(250, 250, 250, 0.4);
            line-height: 1.6;
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 24px 16px 8px;
        }

        .footer p {
            font-size: 12px;
            color: rgba(250, 250, 250, 0.28);
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="brand">
            <span class="brand-name">{{.AppName}}</span>
        </div>

        <div class="card">
            <div class="card-accent"></div>
            <div class="card-body">
                <h1 class="card-title">Reset your password</h1>
                <p class="card-subtitle">We received a password reset request for your account.</p>

                <div class="divider"></div>

                <p class="message">
                    Click the button below to choose a new password. If you didn't request a
                    reset, you can safely ignore this email — your password will remain unchanged.
                </p>

                <div class="btn-wrap">
                    <a href="{{.BaseURL}}/reset/{{.Token}}" class="button">Reset Password</a>
                </div>

                <div class="notice">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="9" stroke="rgba(250,250,250,0.4)" stroke-width="1.6"/>
                        <path d="M12 8v4" stroke="rgba(250,250,250,0.4)" stroke-width="1.6" stroke-linecap="round"/>
                        <circle cx="12" cy="16" r="0.8" fill="rgba(250,250,250,0.4)"/>
                    </svg>
                    <span class="notice-text">This reset link expires in <strong>24 hours</strong>. After that you'll need to request a new one.</span>
                </div>

                <p class="note">
                    If you have concerns or did not request this, please contact our support team.
                </p>
            </div>
        </div>

        <div class="footer">
            <p>&copy; {{.Year}} {{.AppName}}. All rights reserved.</p>
        </div>
    </div>
</body>
</html>
